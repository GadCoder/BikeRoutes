GOOGLE_ISSUERS=accounts.google.com,https://accounts.google.com

# Web (Vite)
VITE_GOOGLE_CLIENT_ID=

# Mobile (Expo)
EXPO_PUBLIC_GOOGLE_CLIENT_ID=

# Tiles (Martin)
MARTIN_PORT=3000
