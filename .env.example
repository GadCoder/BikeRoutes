# Shared
APP_ENV=development

# Database (docker compose)
POSTGRES_USER=bikeroutes
POSTGRES_PASSWORD=bikeroutes
POSTGRES_DB=bikeroutes
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DATABASE_URL=postgresql+asyncpg://bikeroutes:bikeroutes@localhost:5432/bikeroutes
CORS_ORIGINS=http://localhost:5173
JWT_SECRET=dev-insecure-change-me
GOOGLE_CLIENT_IDS=
